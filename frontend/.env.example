# Variáveis de ambiente públicas
# Dashboard Financeiro - Bandeirantes MS

NEXT_PUBLIC_APP_NAME=Dashboard Financeiro Bandeirantes
NEXT_PUBLIC_MUNICIPIO=Bandeirantes - MS
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_API_TIMEOUT=30000

# Feature flags
NEXT_PUBLIC_ENABLE_WEBSOCKET=false
NEXT_PUBLIC_ENABLE_FORECAST=true
NEXT_PUBLIC_ENABLE_EXPORT=true

# Configurações
NEXT_PUBLIC_REFRESH_INTERVAL=60000
NEXT_PUBLIC_DEFAULT_YEAR=2024